# elster-forms-api configuration. Copy to `.env` and adjust.
# Every variable is optional unless marked REQUIRED.

# Transport: "stdio" (default, for Claude Desktop / Claude Code) or "http".
# Override with --transport on the command line if needed.
TRANSPORT=stdio

# HTTP transport only:
#   PORT defaults to 8080.
#   HOST defaults to 0.0.0.0 (listen on all interfaces).
#   AUTH_TOKEN is REQUIRED for the HTTP transport; clients send it as
#   `Authorization: Bearer <token>`. The stdio transport ignores it.
PORT=8080
HOST=0.0.0.0
AUTH_TOKEN=

# Logging:
#   LOG_LEVEL ∈ silent | error | warn | info | debug. Default: info.
LOG_LEVEL=info

# Optional overrides. Resolve relative to the package root.
#   DATA_DIR points at the catalogue tree that ships with the package.
#   SESSIONS_DIR points at the per-installation session store.
# DATA_DIR=
# SESSIONS_DIR=data/sessions

# Optional: override the data_commit string published in tool responses.
# Defaults to the value from the trigger-index file, then falls back to
# the package.json version.
# DATA_COMMIT=
